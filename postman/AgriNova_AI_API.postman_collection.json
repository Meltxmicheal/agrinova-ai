{
  "info": {
    "name": "AgriNova AI — REST API Collection",
    "_postman_id": "agrinova-ai-2026",
    "description": "Complete API collection for the AgriNova AI Smart Agriculture platform.\n\nIncludes: Auth, Farm CRUD, Weather, Crop Recommendation, Yield Prediction, Disease Detection, Fertilizer Recommendation, Market Price Prediction, Dashboard Stats, and Reports Export.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "ACCESS_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "REFRESH_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "FARM_ID",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{ACCESS_TOKEN}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Test Farmer\",\n  \"email\": \"farmer@agrinova.ai\",\n  \"phone\": \"+919876543210\",\n  \"password\": \"Test@1234!\",\n  \"confirm_password\": \"Test@1234!\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/auth/register", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.success) { pm.test('Registration successful', () => pm.response.to.have.status(201)); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"farmer@agrinova.ai\",\n  \"password\": \"Test@1234!\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/auth/login", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.success) {",
                  "  pm.environment.set('ACCESS_TOKEN', data.access_token);",
                  "  pm.environment.set('REFRESH_TOKEN', data.refresh_token);",
                  "  pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/api/auth/profile", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "profile"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"farmer@agrinova.ai\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/auth/forgot-password", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<paste-token-from-forgot-password>\",\n  \"new_password\": \"NewSecure@5678!\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/auth/reset-password", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "reset-password"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{REFRESH_TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/api/auth/refresh", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{BASE_URL}}/api/auth/logout", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "🌾 Farms",
      "item": [
        {
          "name": "Create Farm",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"farm_name\": \"Green Valley Farm\",\n  \"state\": \"Maharashtra\",\n  \"district\": \"Pune\",\n  \"village\": \"Shivpur\",\n  \"soil_type\": \"Loamy\",\n  \"farm_size\": 3.5,\n  \"latitude\": 18.5204,\n  \"longitude\": 73.8567\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/farms/", "host": ["{{BASE_URL}}"], "path": ["api", "farms", ""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.success) {",
                  "  pm.environment.set('FARM_ID', data.farm.id);",
                  "  pm.test('Farm created', () => pm.response.to.have.status(201));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Farms",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/api/farms/", "host": ["{{BASE_URL}}"], "path": ["api", "farms", ""] }
          }
        },
        {
          "name": "Get Single Farm",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/api/farms/{{FARM_ID}}", "host": ["{{BASE_URL}}"], "path": ["api", "farms", "{{FARM_ID}}"] }
          }
        },
        {
          "name": "Update Farm",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"farm_name\": \"Updated Farm Name\",\n  \"soil_type\": \"Black\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/farms/{{FARM_ID}}", "host": ["{{BASE_URL}}"], "path": ["api", "farms", "{{FARM_ID}}"] }
          }
        },
        {
          "name": "Delete Farm",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{BASE_URL}}/api/farms/{{FARM_ID}}", "host": ["{{BASE_URL}}"], "path": ["api", "farms", "{{FARM_ID}}"] }
          }
        }
      ]
    },
    {
      "name": "🌤️ Weather",
      "item": [
        {
          "name": "Get Farm Weather",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/weather/?farm_id={{FARM_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "weather", ""],
              "query": [
                { "key": "farm_id", "value": "{{FARM_ID}}" }
              ]
            }
          }
        },
        {
          "name": "Get Weather History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/weather/history?farm_id={{FARM_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "weather", "history"],
              "query": [
                { "key": "farm_id", "value": "{{FARM_ID}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🧠 AI — Crop Recommendation",
      "item": [
        {
          "name": "Recommend Crop",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nitrogen\": 90,\n  \"phosphorus\": 42,\n  \"potassium\": 43,\n  \"temperature\": 20.8,\n  \"humidity\": 82.0,\n  \"ph\": 6.5,\n  \"rainfall\": 202.9\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/crop/recommend", "host": ["{{BASE_URL}}"], "path": ["api", "crop", "recommend"] }
          }
        }
      ]
    },
    {
      "name": "🧠 AI — Yield Prediction",
      "item": [
        {
          "name": "Predict Yield",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"state\": \"Maharashtra\",\n  \"crop\": \"rice\",\n  \"season\": \"Kharif\",\n  \"area\": 2.5,\n  \"rainfall\": 1200.0,\n  \"temperature\": 27.5\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/prediction/yield", "host": ["{{BASE_URL}}"], "path": ["api", "prediction", "yield"] }
          }
        }
      ]
    },
    {
      "name": "🧠 AI — Disease Detection",
      "item": [
        {
          "name": "Detect Disease (Image Upload)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{BASE_URL}}/api/disease/detect", "host": ["{{BASE_URL}}"], "path": ["api", "disease", "detect"] }
          }
        }
      ]
    },
    {
      "name": "🧠 AI — Fertilizer",
      "item": [
        {
          "name": "Recommend Fertilizer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"soil_type\": \"Loamy\",\n  \"crop_type\": \"rice\",\n  \"nitrogen\": 37,\n  \"phosphorus\": 0,\n  \"potassium\": 0,\n  \"moisture\": 55.0\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/ai/fertilizer", "host": ["{{BASE_URL}}"], "path": ["api", "ai", "fertilizer"] }
          }
        }
      ]
    },
    {
      "name": "🧠 AI — Market Price",
      "item": [
        {
          "name": "Predict Market Price",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"state\": \"Maharashtra\",\n  \"district\": \"Pune\",\n  \"commodity\": \"Rice\",\n  \"month\": 7\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/prediction/price", "host": ["{{BASE_URL}}"], "path": ["api", "prediction", "price"] }
          }
        }
      ]
    },
    {
      "name": "📊 Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/api/dashboard/stats", "host": ["{{BASE_URL}}"], "path": ["api", "dashboard", "stats"] }
          }
        }
      ]
    },
    {
      "name": "📑 Reports",
      "item": [
        {
          "name": "Export Predictions (CSV)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/reports/export?format=csv&report_type=predictions",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "reports", "export"],
              "query": [
                { "key": "format", "value": "csv" },
                { "key": "report_type", "value": "predictions" }
              ]
            }
          }
        },
        {
          "name": "Export Predictions (Excel)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/reports/export?format=excel&report_type=predictions",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "reports", "export"],
              "query": [
                { "key": "format", "value": "excel" },
                { "key": "report_type", "value": "predictions" }
              ]
            }
          }
        },
        {
          "name": "Export Predictions (PDF)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/reports/export?format=pdf&report_type=predictions",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "reports", "export"],
              "query": [
                { "key": "format", "value": "pdf" },
                { "key": "report_type", "value": "predictions" }
              ]
            }
          }
        },
        {
          "name": "Export Farms (CSV)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/reports/export?format=csv&report_type=farms",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "reports", "export"],
              "query": [
                { "key": "format", "value": "csv" },
                { "key": "report_type", "value": "farms" }
              ]
            }
          }
        },
        {
          "name": "Export Weather (CSV)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/reports/export?format=csv&report_type=weather",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "reports", "export"],
              "query": [
                { "key": "format", "value": "csv" },
                { "key": "report_type", "value": "weather" }
              ]
            }
          }
        }
      ]
    }
  ]
}
